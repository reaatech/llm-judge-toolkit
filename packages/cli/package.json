{
  "name": "@reaatech/llm-judge-cli",
  "version": "0.1.0",
  "description": "CLI for LLM Judge Toolkit — evaluate and calibrate commands",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/llm-judge-toolkit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/reaatech/llm-judge-toolkit/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/reaatech/llm-judge-toolkit/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "llm-judge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/llm-judge-types": "workspace:*",
    "@reaatech/llm-judge-providers": "workspace:*",
    "@reaatech/llm-judge-templates": "workspace:*",
    "@reaatech/llm-judge-engine": "workspace:*",
    "@reaatech/llm-judge-calibration": "workspace:*",
    "@reaatech/llm-judge-cache": "workspace:*",
    "@reaatech/llm-judge-infra": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
