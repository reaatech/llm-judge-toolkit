{
  "name": "@reaatech/llm-judge-templates",
  "version": "0.1.0",
  "description": "Prompt templates for LLM Judge Toolkit evaluation criteria",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/llm-judge-toolkit.git",
    "directory": "packages/templates"
  },
  "homepage": "https://github.com/reaatech/llm-judge-toolkit/tree/main/packages/templates#readme",
  "bugs": { "url": "https://github.com/reaatech/llm-judge-toolkit/issues" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/llm-judge-types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.1.1"
  }
}
