# LLM Judge Toolkit — Environment Variables
# Copy this file to .env and fill in your values

# Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_JUDGE_API_KEY=

# Provider selection (openai | anthropic | local)
LLM_JUDGE_PROVIDER=openai

# Base URL for OpenAI-compatible API endpoints (e.g. Azure, Ollama)
LLM_JUDGE_BASE_URL=

# Request timeout in milliseconds
LLM_JUDGE_TIMEOUT=30000

# Logging level (debug | info | warn | error)
LOG_LEVEL=info

# Cache backend (memory | file | redis)
LLM_JUDGE_CACHE_BACKEND=memory

# Redis connection (required when LLM_JUDGE_CACHE_BACKEND=redis)
REDIS_URL=redis://localhost:6379
