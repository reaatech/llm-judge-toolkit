{
  "name": "llm-judge-toolkit",
  "version": "0.1.0",
  "description": "Calibrated LLM-as-judge library. Multi-judge consensus, position bias detection, calibration against human labels, cost tracking, and caching.",
  "keywords": [
    "llm",
    "judge",
    "evaluation",
    "calibration",
    "bias-detection",
    "consensus",
    "prompt-engineering",
    "typescript",
    "ai",
    "nlp",
    "openai",
    "anthropic",
    "claude",
    "gpt"
  ],
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/llm-judge-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/llm-judge-toolkit/issues"
  },
  "homepage": "https://github.com/reaatech/llm-judge-toolkit#readme",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "bin": {
    "llm-judge": "./dist/cli/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.40.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
