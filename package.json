{
  "name": "llm-judge-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Calibrated LLM-as-judge library. Multi-judge consensus, position bias detection, calibration against human labels, cost tracking, and caching.",
  "type": "module",
  "scripts": {
    "build": "pnpm install && turbo run build",
    "test": "turbo run test",
    "test:watch": "vitest",
    "test:coverage": "turbo run test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "keywords": [
    "llm",
    "judge",
    "evaluation",
    "calibration",
    "bias-detection",
    "consensus",
    "prompt-engineering",
    "typescript",
    "ai",
    "nlp",
    "openai",
    "anthropic",
    "claude",
    "gpt"
  ],
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/llm-judge-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/llm-judge-toolkit/issues"
  },
  "homepage": "https://github.com/reaatech/llm-judge-toolkit#readme",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.28.1",
    "@vitest/coverage-v8": "3.2.4",
    "turbo": "^2.9.14",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
